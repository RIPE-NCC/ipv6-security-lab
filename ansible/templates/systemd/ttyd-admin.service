[Unit]
Description=ttyd admin instance

[Service]
User={{ ansible_facts.env.SUDO_USER or ansible_facts.user_id }}
Group=www-data
RuntimeDirectory=ttyd-admin
UMask=0002
ExecStart=/opt/ttyd -W -i /run/ttyd-admin/admin.sock -t fontSize=14 -t disableLeaveAlert=true tmux -2 new -A -D -s admin
Type=simple
Restart=always

[Install]
WantedBy=default.target
