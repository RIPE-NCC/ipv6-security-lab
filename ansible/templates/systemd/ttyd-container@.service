[Unit]
Description=ttyd-container instance %I

[Service]
User={{ ansible_facts.env.SUDO_USER or ansible_facts.user_id }}
Group=www-data
RuntimeDirectory=ttyd-container
UMask=0002
ExecStart=/opt/ttyd -W -i /run/ttyd-container/%i.sock -t fontSize=14 -t disableLeaveAlert=true tmux -2 -L %i set -g default-command "incus exec %i -t -- bash" \; new -A -D -s %i
Type=simple
Restart=always

[Install]
WantedBy=default.target
